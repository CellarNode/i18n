{
  "name": "@cellarnode/i18n",
  "version": "0.3.3",
  "description": "Shared i18n configuration for CellarNode frontends — language constants, i18next factory, browser locale detection, and common translations.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CellarNode/i18n.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/i18next-config.d.ts",
      "default": "./dist/i18next-config.js"
    },
    "./locales/*": "./locales/*",
    "./scripts/copy-common": "./dist/scripts/copy-common.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "locales"
  ],
  "keywords": [
    "cellarnode",
    "i18n",
    "i18next",
    "internationalization",
    "localization"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^3.0.0"
  },
  "peerDependencies": {
    "react-i18next": ">=15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "react-i18next": "^15.7.4",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
